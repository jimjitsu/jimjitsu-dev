# Copy this file to `.env.local` and fill in real values.
# .env.local is gitignored — do NOT commit it.

# ---------------------------------------------------------------
# Contentful
# ---------------------------------------------------------------

# Space ID — fixed for this project.
CONTENTFUL_SPACE_ID=glsf6lviq3r0

# Environment within the space. Use a dedicated env for this project so other
# work in the space stays isolated. Create it in the Contentful UI before
# running migrations (see CONTENTFUL.md).
CONTENTFUL_ENVIRONMENT=jimjitsu-dev

# Personal Management Token (Settings → API keys → Content management tokens).
# Used by the migration scripts. NEVER commit. NEVER ship to the browser.
CONTENTFUL_MANAGEMENT_TOKEN=your-cma-token-here

# Content Delivery API token — used at runtime to fetch published content.
# Generate per-environment in Settings → API keys → Add API key.
CONTENTFUL_DELIVERY_TOKEN=your-delivery-token-here

# Content Preview API token — used in preview mode to fetch drafts.
# Same screen as the delivery token; copy the "Content Preview API" value.
CONTENTFUL_PREVIEW_TOKEN=your-preview-token-here

# ---------------------------------------------------------------
# OpenRouter — Digital Twin Chatbot (Jimbo-t)
# ---------------------------------------------------------------

# API key from openrouter.ai — server-side only, never expose to the browser.
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model override. Defaults to google/gemini-2.5-flash if omitted.
# Fallback option: anthropic/claude-3-5-haiku-20241022
OPENROUTER_MODEL=google/gemini-2.5-flash
